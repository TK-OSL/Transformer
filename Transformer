        // 6. PRACTICE CALCULATOR LOGIC
        // ==========================================
        
        /**
         * Triggered when typing into the practice inputs.
         * Validates numbers and displays the step-by-step formula.
         */
        function solvePractice() {
            const vp = parseFloat(document.getElementById('prob-vp').value);
            const vs = parseFloat(document.getElementById('prob-vs').value);
            const np = parseFloat(document.getElementById('prob-np').value);
            const container = document.getElementById('practice-solution');
            const dict = i18n[currentLang];

            // Validation check
            if (isNaN(vp) || isNaN(vs) || isNaN(np) || vp <= 0 || np <= 0) {
                container.innerHTML = `<p class="text-red-400 font-sans text-center py-4">${dict.errInput}</p>`;
                return;
            }

            // Calculation
            const ns = (vs * np) / vp;
            const nsFormatted = ns % 1 === 0 ? ns : ns.toFixed(2);

            // Construct KaTeX string
            const solutionString = `\\begin{aligned}
            \\text{${dict.mathPracGoal}} & N_s \\\\[1em]
            \\text{${dict.mathPracFrom}} \\quad & \\frac{N_s}{N_p} = \\frac{V_s}{V_p} \\\\[1em]
            \\text{${dict.mathRearrange}} N_s \\quad & N_s = N_p \\times \\left( \\frac{V_s}{V_p} \\right) \\\\[1em]
            \\text{${dict.mathSub}} \\quad & N_s = ${np} \\times \\left( \\frac{${vs}}{${vp}} \\right) \\\\[1em]
            \\text{${dict.mathResult}} \\quad & N_s = \\mathbf{${nsFormatted} \\text{${dict.mathUnitTurns}}}
            \\end{aligned}`;
            
            try {
                // Safely render the math
                container.innerHTML = katex.renderToString(solutionString, katexOptions);
            } catch (e) {
                container.innerHTML = "<p class='text-red-500'>Error rendering math.</p>";
                console.error(e);
            }
        }
