            document.getElementById('static-eq-2').innerHTML = katex.renderToString("P_{in} = P_{out} \\implies V_p I_p = V_s I_s", katexOptions);
            document.getElementById('static-eq-3').innerHTML = katex.renderToString("\\frac{V_p}{V_s} = \\frac{N_p}{N_s} = \\frac{I_s}{I_p}", katexOptions);

            // Set language to default (en) and run calculations
            setLanguage(currentLang);
        };

        // ==========================================
        // 4. LANGUAGE TOGGLE LOGIC
        // ==========================================
        function setLanguage(lang) {
            currentLang = lang;
            
            // Update Toggle Button Styles
            const btnEn = document.getElementById('btn-en');
            const btnTh = document.getElementById('btn-th');
            
            if (lang === 'en') {
                btnEn.className = "lang-btn active";
                btnTh.className = "lang-btn inactive";
            } else {
                btnEn.className = "lang-btn inactive";
                btnTh.className = "lang-btn active";
            }

            // Update all elements with data-i18n attribute
            document.querySelectorAll('[data-i18n]').forEach(element => {
                const key = element.getAttribute('data-i18n');
                if (i18n[lang][key]) {
                    element.innerHTML = i18n[lang][key];
                }
            });

            // Re-run dynamic renders to update localized math text
            updateSimulation();
            solvePractice();
        }

        // ==========================================
        // 5. SIMULATION & DRAWING LOGIC
        // ==========================================
        
        /**
         * Helper function to draw dynamic SVG Coils
         * @param {string} elementId - target SVG group ID
         * @param {number} xCenter - X-axis location for the coil
         * @param {number} turns - number of physical turns
         * @param {string} color - stroke color code
         * @param {number} voltage - used to calculate glow intensity
         */
        function drawCoils(elementId, xCenter, turns, color, voltage) {
            const container = document.getElementById(elementId);
            container.innerHTML = '';

            // Map actual turns to visual turns to prevent overlapping mess (max 35 visual loops)
            const visualTurns = Math.max(5, Math.min(35, turns / 4)); 
            const spacing = (COIL_END_Y - COIL_START_Y) / visualTurns;
            const wireThickness = Math.max(3, 8 - (visualTurns / 10));

            let y = COIL_START_Y;

            for (let i = 0; i <= visualTurns; i++) {
                // Draw background part of the coil (behind the iron core)
                const bgPath = document.createElementNS("http://www.w3.org/2000/svg", "path");
                bgPath.setAttribute("d", `M ${xCenter - COIL_WIDTH/2 + 10} ${y} Q ${xCenter} ${y - 15} ${xCenter + COIL_WIDTH/2 - 10} ${y}`);
                bgPath.setAttribute("stroke", color);
                bgPath.setAttribute("stroke-width", wireThickness);
                bgPath.setAttribute("fill", "none");
                bgPath.setAttribute("opacity", "0.3");
                container.appendChild(bgPath);

                // Draw foreground part of the coil (in front of the iron core)
                const fgPath = document.createElementNS("http://www.w3.org/2000/svg", "path");
                if (i < visualTurns) {
                   fgPath.setAttribute("d", `M ${xCenter + COIL_WIDTH/2 - 10} ${y} Q ${xCenter} ${y + 20} ${xCenter - COIL_WIDTH/2 + 10} ${y + spacing}`);
                } else {
                   fgPath.setAttribute("d", `M ${xCenter + COIL_WIDTH/2 - 10} ${y} Q ${xCenter} ${y + 10} ${xCenter - COIL_WIDTH/2 + 10} ${y}`);
                }
                fgPath.setAttribute("stroke", color);
                fgPath.setAttribute("stroke-width", wireThickness);
                fgPath.setAttribute("fill", "none");
                fgPath.setAttribute("stroke-linecap", "round");
                
                // Add CSS filter glow effect if voltage is high
                if(voltage > 200 && elementId === 'primary-coils') {
                    fgPath.setAttribute("filter", "url(#glow)");
                }
                
                container.appendChild(fgPath);
                y += spacing;
            }
        }

        /**
         * Main function triggered when sliders are moved.
         * Updates UI numbers, Math display, and re-draws SVG.
         */
        function updateSimulation() {
            const Vp = parseFloat(document.getElementById('input-vp').value);
            const Np = parseFloat(document.getElementById('input-np').value);
            const Ns = parseFloat(document.getElementById('input-ns').value);

            // Update UI Number Values
            document.getElementById('vp-val').innerText = `${Vp} V`;
            document.getElementById('np-num').innerText = Np;
            document.getElementById('ns-num').innerText = Ns;

            // Mathematical Calculation: Vs = Vp * (Ns / Np)
            const Vs = Vp * (Ns / Np);
            // Formatting to remove decimal if it's a whole number
            const vsFormatted = Vs % 1 === 0 ? Vs : Vs.toFixed(1);
            document.getElementById('vs-display').innerText = vsFormatted;

            // Handle UI elements (Badges & Visuals)
            const typeElement = document.getElementById('transformer-type');
            const fluxPulse = document.getElementById('magnetic-pulse');
            const fluxFlow = document.getElementById('magnetic-flow');

            // Determine Transformer Type based on Turns Ratio
            if (Ns > Np) {
                typeElement.innerHTML = i18n[currentLang].typeUp;
                typeElement.className = "w-full text-center py-4 rounded-xl font-bold text-green-100 bg-gradient-to-r from-green-600 to-green-500 shadow-lg text-xl font-heading border-2 border-green-400";
            } else if (Ns < Np) {
                typeElement.innerHTML = i18n[currentLang].typeDown;
                typeElement.className = "w-full text-center py-4 rounded-xl font-bold text-orange-100 bg-gradient-to-r from-orange-600 to-orange-500 shadow-lg text-xl font-heading border-2 border-orange-400";
            } else {
                typeElement.innerHTML = i18n[currentLang].typeIso;
                typeElement.className = "w-full text-center py-4 rounded-xl font-bold text-blue-100 bg-gradient-to-r from-blue-600 to-blue-500 shadow-lg text-xl font-heading border-2 border-blue-400";
            }

            // Generate Step-by-Step Math (Using localized strings)
            const dict = i18n[currentLang];
            const mathString = `\\begin{aligned}
            \\text{${dict.mathFormula}} \\quad & \\frac{V_s}{V_p} = \\frac{N_s}{N_p} \\\\[1em]
            \\text{${dict.mathRearrange} } V_s \\quad & V_s = V_p \\times \\left( \\frac{N_s}{N_p} \\right) \\\\[1em]
            \\text{${dict.mathSub}} \\quad & V_s = ${Vp} \\times \\left( \\frac{${Ns}}{${Np}} \\right) \\\\[1em]
            \\text{${dict.mathResult}} \\quad & V_s = \\mathbf{${vsFormatted} \\text{${dict.mathUnitV}}}
            \\end{aligned}`;

            const mathContainer = document.getElementById('math-calculation');
            try {
                // Render KaTeX to string explicitly and inject (safest for Google Sites)
                mathContainer.innerHTML = katex.renderToString(mathString, katexOptions);
            } catch (e) {
                mathContainer.innerHTML = "<p class='text-red-500'>Error rendering math.</p>";
                console.error(e);
            }

            // Draw SVG dynamic components
            drawCoils('primary-coils', CORE_LEFT_X, Np, '#60a5fa', Vp); // Blue
            drawCoils('secondary-coils', CORE_RIGHT_X, Ns, '#f87171', Vs); // Red
            
            // Map animation speeds and intensity dynamically based on voltage
            // Higher voltage = faster flow and brighter pulse
            const normalizedVp = Math.min(Math.max(Vp, 10), 400); // clamp between 10-400
            
            // Flux Flow Animation
            const flowSpeed = Math.max(0.3, 3.0 - (normalizedVp / 150));
            fluxFlow.style.animationDuration = `${flowSpeed}s`;
            fluxFlow.style.opacity = Math.max(0.3, normalizedVp / 400).toString();

            // Flux Pulse Glow
            const pulseSpeed = Math.max(0.4, 2.5 - (normalizedVp / 150));
            fluxPulse.style.animationDuration = `${pulseSpeed}s`;
            fluxPulse.style.opacity = Math.max(0.2, (normalizedVp / 400) * 0.8).toString();

            const primaryCurrentSpeed = Math.max(0.2, 2.0 - (Vp / 100));
            document.getElementById('anim-primary-current').style.animationDuration = `${primaryCurrentSpeed}s`;

            const secondaryCurrentSpeed = Math.max(0.2, 2.0 - (Vs / 100));
            document.getElementById('anim-secondary-current').style.animationDuration = `${secondaryCurrentSpeed}s`;
        }

